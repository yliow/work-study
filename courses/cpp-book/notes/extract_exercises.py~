'''
extracts exercises from a main.tex file for a given chapter, creates an "exercises" folder if one does not exist.

a given exercises will take the form of "num-of-exercise_chapter.tex", and will be inserted at the line the program found an instance of \begin{ex}, while stripping out the entire exercise block

'''

import os

#extracts an exercise, uses the file name immediately above the main.tex file its looking at as the exercise name, formatted as "1_print_strings.tex"
def extract(file_):
  new_note = []
  exercise_list = []
  ex_ctr = 0
  
  #keeps track of lines to identify insert point
  #read as lines, scan for '\begin{ex}', continue until '\end{ex}' is found, skip if no '\begin{ex}' is found. compilation will terminate if there is no matching '\end{ex}' so this should be ran AFTER a book compilation
  with open(file_ + '/main.tex') as f:
    f = f.readlines()
    for line in f:
      if line.find('\\begin{ex}'):
        #append \begin{ex}
        exercise_list.append(line)
        #and everything in between
        while !line.find('\\end{ex}'):
          exercise_list.append(line)
        #append the \end{ex} line as well
        exercise_list.append(line)

        #write to file
        write = open(file_ + '/exercises/' + str(ex_ctr), 'w')
        
        
        
        write.close()
          
      else:
        new_note.append(line)
        
  return

dir_ = os.getcwd()
